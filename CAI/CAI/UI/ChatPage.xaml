<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CAI.UI.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="8,4,0,12">
            <TextBlock Text="CHAT"
                       FontFamily="{StaticResource CAIHeadingFont}"
                       FontSize="18" Foreground="White"
                       VerticalAlignment="Center" />
            <Border Height="1" Width="30" VerticalAlignment="Center" Margin="4,0,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FF333333" Offset="0" />
                        <GradientStop Color="#FFAAAAAA" Offset="0.5" />
                        <GradientStop Color="#FF222222" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Messages -->
        <ListView x:Name="MessagesList" Grid.Row="1" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16,12" Margin="0,4"
                            CornerRadius="2"
                            MaxWidth="600"
                            Background="#05FFFFFF"
                            BorderBrush="#0DFFFFFF"
                            BorderThickness="1">
                        <!-- Left metallic accent strip -->
                        <Grid>
                            <Border Width="2" HorizontalAlignment="Left" Margin="-12,0,0,0"
                                    CornerRadius="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF333333" Offset="0" />
                                        <GradientStop Color="#FFAAAAAA" Offset="0.5" />
                                        <GradientStop Color="#FF222222" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="{Binding Role}" FontWeight="SemiBold" FontSize="11"
                                           Foreground="#FF555555"
                                           CharacterSpacing="200"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding Content}" TextWrapping="WrapWholeWords"
                                           Foreground="#FFEEEEEE" FontWeight="Light" FontSize="14"
                                           LineHeight="22" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Input bar -->
        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="#05FFFFFF"
                BorderBrush="#0DFFFFFF"
                BorderThickness="1"
                CornerRadius="2"
                Padding="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="MessageInput" Grid.Column="0"
                         PlaceholderText="Type a message..."
                         AcceptsReturn="False"
                         KeyDown="MessageInput_KeyDown"
                         VerticalAlignment="Center"
                         Background="Transparent"
                         BorderThickness="0"
                         FontWeight="Light" />

                <Button Grid.Column="1" Margin="4,0" Click="Send_Click"
                        VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Send">
                    <FontIcon Glyph="&#xE724;" FontSize="16" Foreground="{StaticResource CAISilverBrush}" />
                </Button>

                <Button Grid.Column="2" Click="Voice_Click"
                        VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Voice Input">
                    <FontIcon Glyph="&#xE720;" FontSize="16" Foreground="{StaticResource CAISilverBrush}" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
