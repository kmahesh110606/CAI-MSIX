<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CAI.UI.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24" MaxWidth="700">

            <!-- Header -->
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Account -->
            <Expander Header="Account" IsExpanded="True" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBlock x:Name="UserEmailText" Text="Not signed in" Opacity="0.7" />
                    <TextBlock x:Name="UserNameText" Text="" FontWeight="SemiBold" />
                    <Button Content="Sign Out" Click="SignOut_Click" />
                </StackPanel>
            </Expander>

            <!-- Server -->
            <Expander Header="Server Connection" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <TextBox x:Name="ServerUrlBox" Header="Server URL"
                             PlaceholderText="http://127.0.0.1:8000" />
                    <Button Content="Save" Click="SaveServerUrl_Click" />
                </StackPanel>
            </Expander>

            <!-- AI Model -->
            <Expander Header="AI Model" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ComboBox x:Name="ModelSelector" Header="Preferred Model" Width="300">
                        <ComboBoxItem Content="Phi-3 Mini (ONNX)" Tag="phi-3-mini-onnx" />
                        <ComboBoxItem Content="TinyLlama (GGUF)" Tag="tinyllama-gguf" />
                        <ComboBoxItem Content="Both" Tag="both" />
                    </ComboBox>
                    <Button Content="Save" Click="SaveModel_Click" />
                </StackPanel>
            </Expander>

            <!-- Preferences -->
            <Expander Header="Preferences" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12" Padding="8">
                    <ToggleSwitch x:Name="VoiceToggle" Header="Voice Commands"
                                  Toggled="VoiceToggle_Toggled" />
                    <ToggleSwitch x:Name="NotifToggle" Header="Notifications"
                                  Toggled="NotifToggle_Toggled" />
                    <ToggleSwitch x:Name="AutoStartToggle" Header="Start on Boot"
                                  Toggled="AutoStartToggle_Toggled" />
                </StackPanel>
            </Expander>

            <!-- About -->
            <Expander Header="About" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="8" Padding="8">
                    <TextBlock Text="CAI — Cross-Device AI Assistant" FontWeight="SemiBold" />
                    <TextBlock Text="Version 1.0.0" Opacity="0.6" />
                    <TextBlock Text="Built by Mahesh" Opacity="0.6" />
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</Page>
