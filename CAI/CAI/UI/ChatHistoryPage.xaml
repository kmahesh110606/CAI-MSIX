<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CAI.UI.ChatHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="CHAT HISTORY"
                       FontFamily="{StaticResource CAIHeadingFont}"
                       FontSize="24" Foreground="White" />
            <Border Height="1" HorizontalAlignment="Left" Width="40">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FF333333" Offset="0" />
                        <GradientStop Color="#FFAAAAAA" Offset="0.5" />
                        <GradientStop Color="#FF222222" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Search box -->
        <TextBox Grid.Row="1" PlaceholderText="Search conversations..."
                 Margin="0,8,0,16" MaxWidth="400" HorizontalAlignment="Left" />

        <!-- Empty state -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE81C;" FontSize="48" Foreground="{StaticResource CAIGrayDarkBrush}" />
            <TextBlock Text="No conversations yet"
                       FontSize="16" FontWeight="Light"
                       Foreground="{StaticResource CAIGrayMidBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Your chat history will appear here"
                       FontSize="13" FontWeight="Light"
                       Foreground="{StaticResource CAIGrayDarkBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
