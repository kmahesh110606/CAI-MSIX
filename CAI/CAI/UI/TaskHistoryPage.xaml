<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CAI.UI.TaskHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="Transparent" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,8">
            <TextBlock Text="TASK HISTORY"
                       FontFamily="{StaticResource CAIHeadingFont}"
                       FontSize="24" Foreground="White" />
            <Border Height="1" HorizontalAlignment="Left" Width="40">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FF333333" Offset="0" />
                        <GradientStop Color="#FFAAAAAA" Offset="0.5" />
                        <GradientStop Color="#FF222222" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Filters -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,16">
            <ComboBox PlaceholderText="All Statuses" Width="160">
                <ComboBoxItem Content="All" IsSelected="True" />
                <ComboBoxItem Content="Completed" />
                <ComboBoxItem Content="Pending" />
                <ComboBoxItem Content="Failed" />
            </ComboBox>
            <ComboBox PlaceholderText="All Devices" Width="160">
                <ComboBoxItem Content="All Devices" IsSelected="True" />
            </ComboBox>
        </StackPanel>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE9D5;" FontSize="48" Foreground="{StaticResource CAIGrayDarkBrush}" />
            <TextBlock Text="No tasks executed yet"
                       FontSize="16" FontWeight="Light"
                       Foreground="{StaticResource CAIGrayMidBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Cross-device task history will appear here"
                       FontSize="13" FontWeight="Light"
                       Foreground="{StaticResource CAIGrayDarkBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
