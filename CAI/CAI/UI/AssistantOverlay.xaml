<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CAI.UI.AssistantOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,80">
        <Border CornerRadius="20" Padding="24,16" MinWidth="400"
                Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="12">
                <!-- Status -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <ProgressRing x:Name="ListeningIndicator" IsActive="True" Width="20" Height="20" />
                    <TextBlock x:Name="StatusText" Text="Listening..." VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                </StackPanel>

                <!-- Transcription -->
                <TextBlock x:Name="TranscriptionText" Text="" TextWrapping="WrapWholeWords"
                           HorizontalAlignment="Center" Opacity="0.7" TextAlignment="Center" />

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="Cancel" Click="Cancel_Click" />
                    <Button Content="Execute" Style="{StaticResource AccentButtonStyle}"
                            Click="Execute_Click" x:Name="ExecuteButton" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
