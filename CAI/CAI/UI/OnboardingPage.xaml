<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CAI.UI.OnboardingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#000000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- FlipView for onboarding slides -->
        <FlipView x:Name="OnboardingFlipView"
                  Grid.Row="0"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  Background="Transparent"
                  SelectionChanged="FlipView_SelectionChanged">

            <!-- Slide 1: Welcome -->
            <FlipViewItem>
                <Grid Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" MaxWidth="500">
                        <!-- Audio wave bars -->
                        <StackPanel Orientation="Horizontal" Spacing="4"
                                    HorizontalAlignment="Center" Opacity="0.12" Height="80">
                            <Rectangle Width="8" Height="20" RadiusX="4" RadiusY="4" Fill="White" />
                            <Rectangle Width="8" Height="50" RadiusX="4" RadiusY="4" Fill="White" />
                            <Rectangle Width="8" Height="30" RadiusX="4" RadiusY="4" Fill="White" />
                            <Rectangle Width="8" Height="60" RadiusX="4" RadiusY="4" Fill="White" />
                            <Rectangle Width="8" Height="40" RadiusX="4" RadiusY="4" Fill="White" />
                            <Rectangle Width="8" Height="24" RadiusX="4" RadiusY="4" Fill="White" />
                        </StackPanel>

                        <TextBlock Text="INTELLIGENCE&#x000A;EVERYWHERE"
                                   FontFamily="{StaticResource CAIHeadingFont}"
                                   FontSize="48"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   LineHeight="54"
                                   HorizontalAlignment="Center" />

                        <TextBlock Text="An elite cross-device AI assistant. Seamless synchronization, on-device inference, and zero latency."
                                   FontSize="15" FontWeight="Light"
                                   Foreground="{StaticResource CAIGrayLightBrush}"
                                   TextAlignment="Center" TextWrapping="WrapWholeWords"
                                   MaxWidth="400" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <!-- Slide 2: Voice Commands -->
            <FlipViewItem>
                <Grid Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" MaxWidth="500">
                        <!-- Icon circle -->
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#0AFFFFFF" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE720;" FontSize="36" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="VOICE COMMANDS"
                                   FontFamily="{StaticResource CAIHeadingFont}"
                                   FontSize="32" Foreground="White"
                                   TextAlignment="Center" HorizontalAlignment="Center" />

                        <TextBlock Text="Say &quot;Hey CAI&quot; to activate voice control. Open apps, manage files, and control your device completely hands-free."
                                   FontSize="15" FontWeight="Light"
                                   Foreground="{StaticResource CAIGrayLightBrush}"
                                   TextAlignment="Center" TextWrapping="WrapWholeWords"
                                   MaxWidth="400" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <!-- Slide 3: Cross-Device Sync -->
            <FlipViewItem>
                <Grid Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" MaxWidth="500">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#0AFFFFFF" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8AB;" FontSize="36" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="CROSS-DEVICE SYNC"
                                   FontFamily="{StaticResource CAIHeadingFont}"
                                   FontSize="32" Foreground="White"
                                   TextAlignment="Center" HorizontalAlignment="Center" />

                        <TextBlock Text="Control your PC from your phone, sync chats across devices, and execute tasks remotely through a WebSocket matrix."
                                   FontSize="15" FontWeight="Light"
                                   Foreground="{StaticResource CAIGrayLightBrush}"
                                   TextAlignment="Center" TextWrapping="WrapWholeWords"
                                   MaxWidth="400" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <!-- Slide 4: Local Inference -->
            <FlipViewItem>
                <Grid Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" MaxWidth="500">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#0AFFFFFF" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE7F4;" FontSize="36" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="LOCAL INFERENCE"
                                   FontFamily="{StaticResource CAIHeadingFont}"
                                   FontSize="32" Foreground="White"
                                   TextAlignment="Center" HorizontalAlignment="Center" />

                        <TextBlock Text="Powered by ONNX Runtime. Your data never leaves your device unless explicitly commanded. Pure privacy, zero cloud dependency."
                                   FontSize="15" FontWeight="Light"
                                   Foreground="{StaticResource CAIGrayLightBrush}"
                                   TextAlignment="Center" TextWrapping="WrapWholeWords"
                                   MaxWidth="400" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>

            <!-- Slide 5: Zero Friction -->
            <FlipViewItem>
                <Grid Background="Transparent">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24" MaxWidth="500">
                        <Border Width="80" Height="80" CornerRadius="40"
                                Background="#0AFFFFFF" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE945;" FontSize="36" Foreground="White"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="ZERO FRICTION"
                                   FontFamily="{StaticResource CAIHeadingFont}"
                                   FontSize="32" Foreground="White"
                                   TextAlignment="Center" HorizontalAlignment="Center" />

                        <TextBlock Text="Voice activation, clipboard sync, and remote execution. Designed to be invisible until you need it."
                                   FontSize="15" FontWeight="Light"
                                   Foreground="{StaticResource CAIGrayLightBrush}"
                                   TextAlignment="Center" TextWrapping="WrapWholeWords"
                                   MaxWidth="400" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </FlipViewItem>
        </FlipView>

        <!-- Bottom navigation bar -->
        <Grid Grid.Row="1" Padding="40,16,40,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Back button -->
            <Button x:Name="BackButton" Grid.Column="0"
                    Click="Back_Click"
                    Visibility="Collapsed"
                    Background="Transparent"
                    BorderBrush="{StaticResource CAIGrayDarkBrush}"
                    BorderThickness="1"
                    Padding="24,10"
                    CornerRadius="0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE76B;" FontSize="14" Foreground="{StaticResource CAISilverBrush}" />
                    <TextBlock Text="BACK" FontSize="12" FontWeight="Light"
                               Foreground="{StaticResource CAISilverBrush}"
                               CharacterSpacing="200" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Page indicator dots -->
            <PipsPager x:Name="PageIndicator" Grid.Column="1"
                       NumberOfPages="5"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       SelectedPageIndex="0" />

            <!-- Next / Get Started button -->
            <Button x:Name="NextButton" Grid.Column="2"
                    Click="Next_Click"
                    Background="Transparent"
                    BorderBrush="{StaticResource CAIGrayDarkBrush}"
                    BorderThickness="1"
                    Padding="24,10"
                    CornerRadius="0">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="NextButtonText" Text="NEXT" FontSize="12" FontWeight="Light"
                               Foreground="{StaticResource CAISilverBrush}"
                               CharacterSpacing="200" VerticalAlignment="Center" />
                    <FontIcon x:Name="NextButtonIcon" Glyph="&#xE76C;" FontSize="14"
                              Foreground="{StaticResource CAISilverBrush}" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
